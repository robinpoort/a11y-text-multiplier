{
  "manifest_version": 3,
  "name": "A11y Text Multiplier",
  "version": "1.0",
  "description": "Test accessibility by multiplying text on any page. Use 1.5× or 2× to see if elements scale properly with longer text.",
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "A11y Text Multiplier"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
